<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Low supplies (filtered) -->
    <record id="action_reorder_supplies" model="ir.actions.act_window">
        <field name="name">Supplies to Reorder</field>
        <field name="res_model">goliath.supply.item</field>
        <field name="view_mode">list</field>
        <field name="domain">[('is_low', '=', True)]</field>
        <field name="context">{}</field>
    </record>

    <!-- Low chocolate (filtered) -->
    <record id="action_reorder_chocolate" model="ir.actions.act_window">
        <field name="name">Chocolate to Reorder</field>
        <field name="res_model">goliath.chocolate</field>
        <field name="view_mode">list</field>
        <field name="domain">[('is_low', '=', True)]</field>
        <field name="context">{}</field>
    </record>
</odoo>
