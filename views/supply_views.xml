<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_goliath_supply_list" model="ir.ui.view">
        <field name="name">goliath.supply.item.list</field>
        <field name="model">goliath.supply.item</field>
        <field name="arch" type="xml">
            <list string="All Supplies" decoration-danger="is_low">
                <field name="property_id"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="unit"/>
                <field name="reorder_point"/>
                <field name="status"/>
                <field name="is_low" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_goliath_supply" model="ir.actions.act_window">
        <field name="name">All Supplies</field>
        <field name="res_model">goliath.supply.item</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
