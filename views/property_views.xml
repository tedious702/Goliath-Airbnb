<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_goliath_property_list" model="ir.ui.view">
        <field name="name">goliath.property.list</field>
        <field name="model">goliath.property</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="name"/>
                <field name="address"/>
                <field name="supply_count"/>
                <field name="low_count"/>
            </list>
        </field>
    </record>

    <record id="view_goliath_property_form" model="ir.ui.view">
        <field name="name">goliath.property.form</field>
        <field name="model">goliath.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="address"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Supplies">
                            <field name="supply_ids">
                                <list editable="bottom" decoration-danger="is_low">
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="unit"/>
                                    <field name="reorder_point"/>
                                    <field name="status"/>
                                    <field name="is_low" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_goliath_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">goliath.property</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
