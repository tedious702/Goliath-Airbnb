<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_goliath_chocolate_list" model="ir.ui.view">
        <field name="name">goliath.chocolate.list</field>
        <field name="model">goliath.chocolate</field>
        <field name="arch" type="xml">
            <list string="Chocolate Stock" editable="bottom" decoration-danger="is_low">
                <field name="name"/>
                <field name="sku"/>
                <field name="quantity"/>
                <field name="unit"/>
                <field name="reorder_point"/>
                <field name="status"/>
                <field name="is_low" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_goliath_chocolate_form" model="ir.ui.view">
        <field name="name">goliath.chocolate.form</field>
        <field name="model">goliath.chocolate</field>
        <field name="arch" type="xml">
            <form string="Chocolate Product">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sku"/>
                        <field name="quantity"/>
                        <field name="unit"/>
                        <field name="reorder_point"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_goliath_chocolate" model="ir.actions.act_window">
        <field name="name">Chocolate Stock</field>
        <field name="res_model">goliath.chocolate</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
