<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_goliath_airbnb_listing_list" model="ir.ui.view">
        <field name="name">goliath.airbnb.listing.list</field>
        <field name="model">goliath.airbnb.listing</field>
        <field name="arch" type="xml">
            <list string="Listings">
                <field name="name"/>
                <field name="address"/>
                <field name="bedrooms"/>
                <field name="nightly_rate"/>
            </list>
        </field>
    </record>

    <record id="view_goliath_airbnb_listing_form" model="ir.ui.view">
        <field name="name">goliath.airbnb.listing.form</field>
        <field name="model">goliath.airbnb.listing</field>
        <field name="arch" type="xml">
            <form string="Listing">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="address"/>
                        <field name="bedrooms"/>
                        <field name="nightly_rate"/>
                        <field name="active"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_goliath_airbnb_listing" model="ir.actions.act_window">
        <field name="name">Listings</field>
        <field name="res_model">goliath.airbnb.listing</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_goliath_airbnb_root" name="Goliath Airbnb" sequence="15"/>
    <menuitem id="menu_goliath_airbnb_listings" name="Listings"
              parent="menu_goliath_airbnb_root"
              action="action_goliath_airbnb_listing" sequence="10"/>

</odoo>
